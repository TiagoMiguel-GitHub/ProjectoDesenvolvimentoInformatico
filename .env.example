# ---- Backend ----
APP_ENV=development
SECRET_KEY=change-this-to-a-very-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Supabase — copiar de supabase.com > Connect > Direct > URI
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?ssl=require

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

MULTIBANCO_ENTITY=11249
EASYPAY_ACCOUNT_ID=
EASYPAY_API_KEY=
EASYPAY_WEBHOOK_SECRET=

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081
FIRST_ADMIN_EMAIL=admin@agrowood.pt
FIRST_ADMIN_PASSWORD=changeme

# ---- Mobile ----
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# ---- Admin ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
